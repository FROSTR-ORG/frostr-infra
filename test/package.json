{
  "name": "frostr-infra-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test:e2e": "npm run test:e2e:fast && npm run test:e2e:live",
    "test:guards": "bash ./scripts/check-no-legacy-surfaces.sh && bash ./scripts/check-browser-wasm-artifacts.sh && bash ./scripts/test-run-sh.sh",
    "test:e2e:igloo-home": "playwright test -c ./igloo-home/playwright.config.ts",
    "test:e2e:igloo-pwa": "playwright test -c ./igloo-pwa/playwright.config.ts",
    "test:e2e:igloo-pwa:fast": "playwright test -c ./igloo-pwa/playwright.config.ts --grep-invert @live",
    "test:e2e:igloo-pwa:live": "playwright test -c ./igloo-pwa/playwright.config.ts --grep @live",
    "test:e2e:igloo-web": "npm run test:e2e:igloo-pwa",
    "test:e2e:smoke": "bash ./scripts/test-demo-harness-onboard.sh",
    "test:e2e:fast": "npm run test:e2e:igloo-pwa:fast && npm run test:e2e:igloo-chrome:fast",
    "test:e2e:live": "npm run test:e2e:igloo-pwa:live && npm run test:e2e:igloo-chrome:live",
    "test:e2e:demo": "npm run test:e2e:igloo-chrome:demo",
    "test:e2e:igloo-chrome": "playwright test -c ./igloo-chrome/playwright.config.ts",
    "test:e2e:igloo-chrome:demo": "playwright test -c ./igloo-chrome/playwright.config.ts igloo-chrome/specs/demo-harness.spec.ts",
    "test:e2e:igloo-chrome:fast": "playwright test -c ./igloo-chrome/playwright.config.ts --grep-invert @live",
    "test:e2e:igloo-chrome:live": "playwright test -c ./igloo-chrome/playwright.config.ts --grep @live",
    "test:typecheck": "tsc --noEmit",
    "test:run-sh": "bash ./scripts/test-run-sh.sh",
    "test:install-browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@playwright/test": "^1.58.2",
    "@scure/base": "^1.2.6",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "nostr-tools": "^2.17.2",
    "typescript": "^5.9.3",
    "ws": "^8.18.3"
  }
}
